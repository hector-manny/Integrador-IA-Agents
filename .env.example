# Server (positive integer, default 3000)

PORT=3000



# Cache TTL for in-memory cache (seconds, positive integer)

CACHE_TTL_SECONDS=900



# Outbound HTTP client timeout (milliseconds, positive integer)

HTTP_TIMEOUT_MS=5000



# IP geolocation fallback (HTTP free tier by default; see README security section)

IP_API_BASE_URL=http://ip-api.com

